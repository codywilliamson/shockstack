---
interface Props {
  name: string;
  price: string;
  period?: string;
  description: string;
  features: string[];
  cta: string;
  href: string;
  featured?: boolean;
}

const {
  name,
  price,
  period = "/mo",
  description,
  features,
  cta,
  href,
  featured = false,
} = Astro.props;
---

<div class:list={["pricing-card", { "pricing-featured": featured }]}>
  {featured && <div class="pricing-badge">Popular</div>}

  <div class="pricing-header">
    <h3 class="pricing-name">{name}</h3>
    <p class="pricing-description">{description}</p>
  </div>

  <div class="pricing-price-row">
    <span class="pricing-price">{price}</span>
    {
      price !== "Free" && price !== "Custom" && (
        <span class="pricing-period">{period}</span>
      )
    }
  </div>

  <ul class="pricing-features">
    {
      features.map((feature) => (
        <li class="pricing-feature">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="pricing-check"
          >
            <polyline points="20 6 9 17 4 12" />
          </svg>
          {feature}
        </li>
      ))
    }
  </ul>

  <a
    href={href}
    class:list={["pricing-cta", { "pricing-cta-featured": featured }]}
  >
    {cta}
  </a>
</div>

<style>
  .pricing-card {
    position: relative;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: all 0.2s ease;
  }

  .pricing-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .pricing-featured {
    border-color: var(--color-accent-purple);
    background: linear-gradient(
      180deg,
      color-mix(
        in srgb,
        var(--color-accent-purple) 6%,
        var(--color-bg-secondary)
      ),
      var(--color-bg-secondary) 40%
    );
    box-shadow:
      0 0 0 1px var(--color-accent-purple),
      0 0 40px -12px
        color-mix(in srgb, var(--color-accent-purple) 25%, transparent);
  }

  .pricing-featured:hover {
    box-shadow:
      0 0 0 1px var(--color-accent-purple),
      0 0 60px -12px
        color-mix(in srgb, var(--color-accent-purple) 35%, transparent);
  }

  .pricing-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(
      135deg,
      var(--color-accent-purple),
      var(--color-accent-pink)
    );
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 1rem;
    border-radius: var(--radius-full);
    letter-spacing: 0.025em;
  }

  .pricing-header {
    margin-bottom: 1.5rem;
  }

  .pricing-name {
    color: var(--color-fg-primary);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.375rem;
  }

  .pricing-description {
    color: var(--color-fg-muted);
    font-size: 0.875rem;
  }

  .pricing-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-bottom: 2rem;
  }

  .pricing-price {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    background: linear-gradient(
      135deg,
      var(--color-fg-primary),
      var(--color-fg-secondary)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pricing-featured .pricing-price {
    background: linear-gradient(
      135deg,
      var(--color-accent-purple),
      var(--color-accent-pink)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pricing-period {
    color: var(--color-fg-muted);
    font-size: 0.875rem;
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .pricing-feature {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-fg-secondary);
    font-size: 0.875rem;
  }

  .pricing-check {
    color: var(--color-accent-green);
    flex-shrink: 0;
  }

  .pricing-cta {
    display: block;
    text-align: center;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    font-size: 0.875rem;
    border: 1px solid var(--color-border-default);
    color: var(--color-fg-primary);
    background-color: var(--color-bg-tertiary);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .pricing-cta:hover {
    border-color: var(--color-accent-purple);
    background-color: var(--color-bg-secondary);
  }

  .pricing-cta-featured {
    border: none;
    background: linear-gradient(
      135deg,
      var(--color-accent-purple),
      var(--color-accent-pink)
    );
    color: white;
  }

  .pricing-cta-featured:hover {
    opacity: 0.9;
    background: linear-gradient(
      135deg,
      var(--color-accent-purple),
      var(--color-accent-pink)
    );
  }
</style>
