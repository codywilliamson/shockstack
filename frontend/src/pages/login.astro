---
import BaseLayout from "../layouts/BaseLayout.astro";
import AuthForm from "../components/ui/AuthForm.vue";

if (Astro.locals.user) {
  return Astro.redirect("/dashboard");
}
---

<BaseLayout title="Login" noindex>
  <div class="flex flex-col items-center py-16">
    <h1 class="mb-8 text-3xl font-bold">Sign In</h1>
    <AuthForm mode="login" client:load />
    <p class="text-fg-secondary mt-4 text-sm">
      Don't have an account?
      <a href="/register" class="text-accent-purple hover:underline">
        Create one
      </a>
    </p>
    <div
      class="border-border-default bg-bg-secondary mt-6 max-w-sm rounded-lg border p-4 text-center"
    >
      <p
        class="text-fg-muted mb-1 text-xs font-medium tracking-wider uppercase"
      >
        Demo Account
      </p>
      <p class="text-fg-secondary text-sm">
        <code class="bg-bg-tertiary rounded px-1 py-0.5 text-xs"
          >demo@shockstack.dev</code
        >
        /
        <code class="bg-bg-tertiary rounded px-1 py-0.5 text-xs"
          >password123</code
        >
      </p>
    </div>
  </div>
</BaseLayout>
