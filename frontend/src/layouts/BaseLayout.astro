---
import { ViewTransitions } from "astro:transitions";
import SEO from "../components/ui/SEO.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import {
  DEFAULT_THEME,
  LIGHT_PREFERRED_THEME,
  VALID_THEMES,
} from "../lib/themes";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  fullWidth?: boolean;
  noindex?: boolean;
}

const {
  title,
  description,
  image,
  type,
  fullWidth = false,
  noindex,
} = Astro.props;

const themeBootstrapScript = `
(() => {
  const validThemes = ${JSON.stringify(VALID_THEMES)};
  const storedTheme = localStorage.getItem("theme");
  const resolvedTheme =
    storedTheme && validThemes.includes(storedTheme)
      ? storedTheme
      : (window.matchMedia("(prefers-color-scheme: light)").matches
        ? "${LIGHT_PREFERRED_THEME}"
        : "${DEFAULT_THEME}");
  document.documentElement.setAttribute("data-theme", resolvedTheme);
})();
`;
---

<html lang="en" data-theme="dark">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
    />
    <ViewTransitions />
    <script is:inline set:html={themeBootstrapScript} />
  </head>
  <body class="bg-bg-primary text-fg-primary flex min-h-screen flex-col">
    <Header />
    <main
      class:list={[
        "flex-1",
        fullWidth ? "w-full" : "mx-auto w-full max-w-6xl px-4 py-8",
      ]}
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>
