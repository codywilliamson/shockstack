---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Login" noindex>
  <div class="flex flex-col items-center py-16">
    <h1 class="mb-8 text-3xl font-bold">Sign In</h1>
    <div
      class="border-border-default bg-bg-secondary max-w-md rounded-lg border p-6 text-center"
    >
      <div class="text-fg-muted mb-3 text-4xl">🔒</div>
      <h2 class="text-fg-primary mb-2 text-lg font-semibold">
        Authentication Disabled
      </h2>
      <p class="text-fg-secondary text-sm leading-relaxed">
        Auth is not available in this deployment. ShockStack is a template —
        connect your own database and API backend to enable authentication.
      </p>
      <a
        href="/docs/authentication"
        class="bg-accent-purple text-bg-primary mt-4 inline-block rounded-md px-4 py-2 text-sm font-medium transition-opacity hover:opacity-90"
      >
        View Auth Docs
      </a>
    </div>
  </div>
</BaseLayout>
