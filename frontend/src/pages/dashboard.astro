---
import BaseLayout from "../layouts/BaseLayout.astro";

const user = Astro.locals.user!;
---

<BaseLayout title="Dashboard" noindex>
  <div class="py-8">
    <h1 class="mb-4 text-3xl font-bold">Dashboard</h1>
    <div class="border-border-default rounded-lg border p-6">
      <p class="text-fg-secondary">
        Welcome back, <span class="text-fg-primary font-semibold"
          >{user.name}</span
        >
      </p>
      <p class="text-fg-muted mt-2 text-sm">{user.email}</p>
    </div>
  </div>
</BaseLayout>
