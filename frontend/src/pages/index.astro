---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout title="ShockStack">
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-accent-purple mb-4 text-5xl font-bold">ShockStack</h1>
    <p class="text-fg-secondary mb-8 max-w-2xl text-xl">
      Convention-first monorepo template with Astro 5, Vue 3, Tailwind 4, and
      optional .NET 10 backend.
    </p>
    <div class="flex gap-4">
      <a
        href="/docs"
        class="bg-accent-purple text-bg-primary rounded-lg px-6 py-3 font-semibold transition-opacity hover:opacity-90"
      >
        Get Started
      </a>
      <a
        href="/blog"
        class="border-border-default text-fg-primary hover:border-accent-purple rounded-lg border px-6 py-3 font-semibold transition-colors"
      >
        Read Blog
      </a>
    </div>
  </div>
</BaseLayout>
