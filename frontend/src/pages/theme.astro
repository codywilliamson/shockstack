---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeHero from "../components/theme/ThemeHero.astro";
import AccentColors from "../components/theme/AccentColors.astro";
import SurfaceColors from "../components/theme/SurfaceColors.astro";
import TypographyShowcase from "../components/theme/TypographyShowcase.astro";
import SpacingScale from "../components/theme/SpacingScale.astro";
import RadiusShowcase from "../components/theme/RadiusShowcase.astro";
import ShadowShowcase from "../components/theme/ShadowShowcase.astro";
import ComponentExamples from "../components/theme/ComponentExamples.astro";
import TokenReference from "../components/theme/TokenReference.astro";

export const prerender = true;
---

<BaseLayout
  title="Theme Showcase — ShockStack"
  description="Interactive showcase of the ShockStack design token system — Dracula dark and Alucard light themes."
  fullWidth
>
  <ThemeHero />
  <AccentColors />
  <SurfaceColors />
  <TypographyShowcase />
  <SpacingScale />
  <RadiusShowcase />
  <ShadowShowcase />
  <ComponentExamples />
  <TokenReference />
</BaseLayout>

<style>
  .section-header {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .section-desc {
    color: var(--color-fg-secondary);
    max-width: 40rem;
  }

  .theme-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    padding: 1.25rem;
  }
</style>
