{
  "name": "shockstack",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.4.1",
  "lint-staged": {
    "*.{ts,tsx,vue,astro,js,cjs,mjs}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,vue,astro,js,cjs,mjs,json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
