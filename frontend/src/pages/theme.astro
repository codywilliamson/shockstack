---
import BaseLayout from "../layouts/BaseLayout.astro";
import ColorSwatch from "../components/theme/ColorSwatch.vue";
import tokensDark from "../../../packages/tokens/dist/tokens-dark.json";
import tokensLight from "../../../packages/tokens/dist/tokens-light.json";

export const prerender = true;

const accentColors = [
  { name: "Purple", cssVar: "--color-accent-purple", tw: "bg-accent-purple" },
  { name: "Pink", cssVar: "--color-accent-pink", tw: "bg-accent-pink" },
  { name: "Green", cssVar: "--color-accent-green", tw: "bg-accent-green" },
  { name: "Cyan", cssVar: "--color-accent-cyan", tw: "bg-accent-cyan" },
  { name: "Orange", cssVar: "--color-accent-orange", tw: "bg-accent-orange" },
  { name: "Red", cssVar: "--color-accent-red", tw: "bg-accent-red" },
  { name: "Yellow", cssVar: "--color-accent-yellow", tw: "bg-accent-yellow" },
];

const surfaceColors = [
  {
    name: "BG Primary",
    cssVar: "--color-bg-primary",
    tw: "bg-bg-primary",
    variant: "bg" as const,
  },
  {
    name: "BG Secondary",
    cssVar: "--color-bg-secondary",
    tw: "bg-bg-secondary",
    variant: "bg" as const,
  },
  {
    name: "BG Tertiary",
    cssVar: "--color-bg-tertiary",
    tw: "bg-bg-tertiary",
    variant: "bg" as const,
  },
  {
    name: "FG Primary",
    cssVar: "--color-fg-primary",
    tw: "text-fg-primary",
    variant: "fg" as const,
  },
  {
    name: "FG Secondary",
    cssVar: "--color-fg-secondary",
    tw: "text-fg-secondary",
    variant: "fg" as const,
  },
  {
    name: "FG Muted",
    cssVar: "--color-fg-muted",
    tw: "text-fg-muted",
    variant: "fg" as const,
  },
  {
    name: "Border Default",
    cssVar: "--color-border-default",
    tw: "border-border-default",
    variant: "border" as const,
  },
  {
    name: "Border Muted",
    cssVar: "--color-border-muted",
    tw: "border-border-muted",
    variant: "border" as const,
  },
  {
    name: "Selection",
    cssVar: "--color-selection",
    tw: "bg-selection",
    variant: "bg" as const,
  },
];

const fontSizes = [
  { name: "xs", var: "--ss-font-size-xs", value: "0.75rem" },
  { name: "sm", var: "--ss-font-size-sm", value: "0.875rem" },
  { name: "base", var: "--ss-font-size-base", value: "1rem" },
  { name: "lg", var: "--ss-font-size-lg", value: "1.125rem" },
  { name: "xl", var: "--ss-font-size-xl", value: "1.25rem" },
  { name: "2xl", var: "--ss-font-size-2xl", value: "1.5rem" },
  { name: "3xl", var: "--ss-font-size-3xl", value: "1.875rem" },
  { name: "4xl", var: "--ss-font-size-4xl", value: "2.25rem" },
  { name: "5xl", var: "--ss-font-size-5xl", value: "3rem" },
];

const spacingScale = [
  { name: "spacing-1", var: "--ss-spacing-1", value: "0.25rem" },
  { name: "spacing-2", var: "--ss-spacing-2", value: "0.5rem" },
  { name: "spacing-3", var: "--ss-spacing-3", value: "0.75rem" },
  { name: "spacing-4", var: "--ss-spacing-4", value: "1rem" },
  { name: "spacing-5", var: "--ss-spacing-5", value: "1.25rem" },
  { name: "spacing-6", var: "--ss-spacing-6", value: "1.5rem" },
  { name: "spacing-8", var: "--ss-spacing-8", value: "2rem" },
  { name: "spacing-10", var: "--ss-spacing-10", value: "2.5rem" },
  { name: "spacing-12", var: "--ss-spacing-12", value: "3rem" },
  { name: "spacing-16", var: "--ss-spacing-16", value: "4rem" },
  { name: "spacing-20", var: "--ss-spacing-20", value: "5rem" },
  { name: "spacing-24", var: "--ss-spacing-24", value: "6rem" },
];

const radii = [
  { name: "none", var: "--ss-radius-none", value: "0" },
  { name: "sm", var: "--ss-radius-sm", value: "0.25rem" },
  { name: "md", var: "--ss-radius-md", value: "0.375rem" },
  { name: "lg", var: "--ss-radius-lg", value: "0.5rem" },
  { name: "xl", var: "--ss-radius-xl", value: "0.75rem" },
  { name: "2xl", var: "--ss-radius-2xl", value: "1rem" },
  { name: "full", var: "--ss-radius-full", value: "9999px" },
];

const shadows = [
  { name: "sm", var: "--ss-shadow-sm" },
  { name: "md", var: "--ss-shadow-md" },
  { name: "lg", var: "--ss-shadow-lg" },
  { name: "xl", var: "--ss-shadow-xl" },
];

// build token reference from JSON
type TokenEntry = {
  token: string;
  cssVar: string;
  tailwind: string;
  dark: string;
  light: string;
};
const tokenRef: TokenEntry[] = [];
const darkEntries = Object.entries(tokensDark) as [string, string][];
for (const [key, darkVal] of darkEntries) {
  const lightVal = (tokensLight as Record<string, string>)[key] ?? "";
  const cssVar = `--ss-${key.replace(/\./g, "-")}`;
  let tw = "";
  if (key.startsWith("color-accent-"))
    tw = `bg-accent-${key.replace("color-accent-", "")}`;
  else if (key.startsWith("color-bg-"))
    tw = `bg-bg-${key.replace("color-bg-", "")}`;
  else if (key.startsWith("color-fg-"))
    tw = `text-fg-${key.replace("color-fg-", "")}`;
  else if (key.startsWith("color-border-"))
    tw = `border-border-${key.replace("color-border-", "")}`;
  else if (key.startsWith("color-")) tw = `bg-${key.replace("color-", "")}`;
  tokenRef.push({
    token: key,
    cssVar,
    tailwind: tw,
    dark: darkVal,
    light: lightVal,
  });
}
---

<BaseLayout
  title="Theme Showcase — ShockStack"
  description="Interactive showcase of the ShockStack design token system — Dracula dark and Alucard light themes."
  fullWidth
>
  <!-- hero -->
  <section class="px-4 pt-20 pb-16 md:pt-28 md:pb-20">
    <div class="mx-auto max-w-5xl text-center">
      <h1 class="fade-in mb-4 text-4xl font-extrabold md:text-6xl">
        Theme <span class="theme-gradient">Showcase</span>
      </h1>
      <p class="fade-in text-fg-secondary mx-auto max-w-2xl text-lg">
        The full ShockStack design token system. Toggle the theme with the
        switch in the header — all values update live.
      </p>
    </div>
  </section>

  <!-- accent colors -->
  <section class="reveal px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="section-header">
        <h2 class="section-title">Accent Colors</h2>
        <p class="section-desc">
          7 accent colors from the Dracula / Alucard palettes. Click any swatch
          to copy its hex value.
        </p>
      </div>
      <div
        class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7"
      >
        {
          accentColors.map((c) => (
            <ColorSwatch
              client:visible
              name={c.name}
              cssVar={c.cssVar}
              tailwindClass={c.tw}
              variant="accent"
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- surface colors -->
  <section class="reveal bg-bg-secondary/50 px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="section-header">
        <h2 class="section-title">Surface Colors</h2>
        <p class="section-desc">
          Backgrounds, foregrounds, borders, and selection colors that define
          the UI chrome.
        </p>
      </div>
      <div
        class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5"
      >
        {
          surfaceColors.map((c) => (
            <ColorSwatch
              client:visible
              name={c.name}
              cssVar={c.cssVar}
              tailwindClass={c.tw}
              variant={c.variant}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- typography -->
  <section class="reveal px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="section-header">
        <h2 class="section-title">Typography</h2>
        <p class="section-desc">Font families, size scale, and weight demos.</p>
      </div>

      <!-- font families -->
      <div class="mb-12 grid gap-6 md:grid-cols-2">
        <div class="theme-card">
          <h3
            class="text-fg-muted mb-2 text-sm font-semibold tracking-wider uppercase"
          >
            Sans — Inter
          </h3>
          <p
            class="text-2xl font-semibold"
            style="font-family: var(--font-sans)"
          >
            The quick brown fox jumps over the lazy dog
          </p>
          <code class="text-fg-muted mt-2 inline-block text-xs"
            >--font-sans</code
          >
        </div>
        <div class="theme-card">
          <h3
            class="text-fg-muted mb-2 text-sm font-semibold tracking-wider uppercase"
          >
            Mono — JetBrains Mono
          </h3>
          <p
            class="text-2xl font-semibold"
            style="font-family: var(--font-mono)"
          >
            const x = () =&gt; 42;
          </p>
          <code class="text-fg-muted mt-2 inline-block text-xs"
            >--font-mono</code
          >
        </div>
      </div>

      <!-- font size scale -->
      <div class="theme-card mb-12">
        <h3
          class="text-fg-muted mb-6 text-sm font-semibold tracking-wider uppercase"
        >
          Size Scale
        </h3>
        <div class="space-y-4">
          {
            fontSizes.map((fs) => (
              <div class="flex items-baseline gap-4">
                <code class="text-fg-muted w-20 shrink-0 text-right font-mono text-xs">
                  {fs.name}
                </code>
                <span style={`font-size: ${fs.value}`}>ShockStack</span>
                <span class="text-fg-muted ml-auto font-mono text-xs">
                  {fs.value}
                </span>
              </div>
            ))
          }
        </div>
      </div>

      <!-- font weights -->
      <div class="theme-card">
        <h3
          class="text-fg-muted mb-6 text-sm font-semibold tracking-wider uppercase"
        >
          Weights
        </h3>
        <div class="flex flex-wrap gap-8 text-2xl">
          <span style="font-weight: 400"
            >Normal <code class="text-fg-muted text-xs">400</code></span
          >
          <span style="font-weight: 500"
            >Medium <code class="text-fg-muted text-xs">500</code></span
          >
          <span style="font-weight: 600"
            >Semibold <code class="text-fg-muted text-xs">600</code></span
          >
          <span style="font-weight: 700"
            >Bold <code class="text-fg-muted text-xs">700</code></span
          >
        </div>
      </div>
    </div>
  </section>

  <!-- spacing -->
  <section class="reveal bg-bg-secondary/50 px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="section-header">
        <h2 class="section-title">Spacing Scale</h2>
        <p class="section-desc">
          Consistent spacing tokens mapped to CSS custom properties.
        </p>
      </div>
      <div class="theme-card">
        <div class="space-y-3">
          {
            spacingScale.map((s) => (
              <div class="flex items-center gap-4">
                <code class="text-fg-muted w-28 shrink-0 font-mono text-xs">
                  {s.name}
                </code>
                <div class="flex-1">
                  <div
                    class="bg-accent-purple h-3 rounded-sm"
                    style={`width: var(${s.var}); min-width: 2px;`}
                  />
                </div>
                <span class="text-fg-muted w-20 shrink-0 text-right font-mono text-xs">
                  {s.value}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- border radius -->
  <section class="reveal px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="section-header">
        <h2 class="section-title">Border Radius</h2>
        <p class="section-desc">Radius tokens from sharp to fully rounded.</p>
      </div>
      <div class="flex flex-wrap items-end gap-6">
        {
          radii.map((r) => (
            <div class="flex flex-col items-center gap-2">
              <div
                class="border-accent-purple bg-accent-purple/20 h-16 w-16 border-2"
                style={`border-radius: var(${r.var})`}
              />
              <code class="text-fg-muted font-mono text-xs">{r.name}</code>
              <span class="text-fg-muted font-mono text-[0.625rem]">
                {r.value}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- shadows -->
  <section class="reveal bg-bg-secondary/50 px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="section-header">
        <h2 class="section-title">Shadows</h2>
        <p class="section-desc">Elevation levels from subtle to dramatic.</p>
      </div>
      <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
        {
          shadows.map((s) => (
            <div
              class="border-border-default bg-bg-primary flex h-28 items-center justify-center rounded-xl border"
              style={`box-shadow: var(${s.var})`}
            >
              <code class="text-fg-muted font-mono text-sm">
                shadow-{s.name}
              </code>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- component examples -->
  <section class="reveal px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="section-header">
        <h2 class="section-title">Component Examples</h2>
        <p class="section-desc">
          Common UI patterns built with the design token system.
        </p>
      </div>

      <!-- buttons -->
      <div class="mb-12">
        <h3
          class="text-fg-muted mb-4 text-sm font-semibold tracking-wider uppercase"
        >
          Buttons
        </h3>
        <div class="flex flex-wrap gap-3">
          <button class="btn-primary">Primary</button>
          <button class="btn-secondary">Secondary</button>
          <button class="btn-destructive">Destructive</button>
          <button class="btn-ghost">Ghost</button>
        </div>
        <div class="mt-4 flex flex-wrap gap-3">
          <button class="btn-accent bg-accent-purple text-bg-primary"
            >Purple</button
          >
          <button class="btn-accent bg-accent-pink text-bg-primary">Pink</button
          >
          <button class="btn-accent bg-accent-green text-bg-primary"
            >Green</button
          >
          <button class="btn-accent bg-accent-cyan text-bg-primary">Cyan</button
          >
          <button class="btn-accent bg-accent-orange text-bg-primary"
            >Orange</button
          >
          <button class="btn-accent bg-accent-red text-bg-primary">Red</button>
          <button class="btn-accent bg-accent-yellow text-bg-primary"
            >Yellow</button
          >
        </div>
      </div>

      <!-- badges -->
      <div class="mb-12">
        <h3
          class="text-fg-muted mb-4 text-sm font-semibold tracking-wider uppercase"
        >
          Badges
        </h3>
        <div class="flex flex-wrap gap-2">
          <span class="badge badge-purple">Purple</span>
          <span class="badge badge-pink">Pink</span>
          <span class="badge badge-green">Green</span>
          <span class="badge badge-cyan">Cyan</span>
          <span class="badge badge-orange">Orange</span>
          <span class="badge badge-red">Red</span>
          <span class="badge badge-yellow">Yellow</span>
        </div>
      </div>

      <!-- cards -->
      <div class="mb-12">
        <h3
          class="text-fg-muted mb-4 text-sm font-semibold tracking-wider uppercase"
        >
          Cards
        </h3>
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="theme-card">
            <h4 class="mb-2 font-semibold">Default Card</h4>
            <p class="text-fg-secondary text-sm">
              A standard card with secondary background and default border.
            </p>
          </div>
          <div
            class="theme-card hover:border-accent-purple transition-all hover:-translate-y-0.5 hover:shadow-lg"
          >
            <h4 class="mb-2 font-semibold">Interactive Card</h4>
            <p class="text-fg-secondary text-sm">
              Hover for purple border accent and elevation shadow.
            </p>
          </div>
          <div
            class="border-accent-purple bg-accent-purple/10 rounded-xl border p-5"
          >
            <h4 class="text-accent-purple mb-2 font-semibold">Accent Card</h4>
            <p class="text-fg-secondary text-sm">
              Highlighted with accent background tint and border.
            </p>
          </div>
        </div>
      </div>

      <!-- form inputs -->
      <div class="mb-12">
        <h3
          class="text-fg-muted mb-4 text-sm font-semibold tracking-wider uppercase"
        >
          Form Inputs
        </h3>
        <div class="grid max-w-2xl gap-4 sm:grid-cols-2">
          <input type="text" placeholder="Text input" class="theme-input" />
          <input type="email" placeholder="Email input" class="theme-input" />
          <select class="theme-input">
            <option>Select option</option>
            <option>Option A</option>
            <option>Option B</option>
          </select>
          <textarea placeholder="Textarea" rows="1" class="theme-input"
          ></textarea>
        </div>
      </div>

      <!-- links -->
      <div class="mb-12">
        <h3
          class="text-fg-muted mb-4 text-sm font-semibold tracking-wider uppercase"
        >
          Links
        </h3>
        <div class="flex flex-wrap gap-6">
          <a
            href="#"
            class="text-accent-purple hover:text-accent-pink underline underline-offset-2 transition-colors"
            >Default link</a
          >
          <a
            href="#"
            class="text-fg-secondary hover:text-fg-primary transition-colors"
            >Muted link</a
          >
          <a
            href="#"
            class="text-accent-cyan hover:text-accent-green font-mono text-sm transition-colors"
            >Mono link</a
          >
        </div>
      </div>

      <!-- code block -->
      <div>
        <h3
          class="text-fg-muted mb-4 text-sm font-semibold tracking-wider uppercase"
        >
          Code Block
        </h3>
        <div class="code-block">
          <div class="code-header">
            <span class="text-fg-muted font-mono text-xs">tokens.config.ts</span
            >
          </div>
          <pre
            class="code-body"><code><span class="text-accent-purple">import</span> <span class="text-fg-primary">StyleDictionary</span> <span class="text-accent-purple">from</span> <span class="text-accent-yellow">"style-dictionary"</span><span class="text-fg-muted">;</span>
<span class="text-accent-purple">export default</span> <span class="text-fg-muted">&#123;</span>
  <span class="text-accent-cyan">source</span><span class="text-fg-muted">:</span> <span class="text-fg-muted">[</span><span class="text-accent-yellow">"tokens/**/*.json"</span><span class="text-fg-muted">],</span>
  <span class="text-accent-cyan">platforms</span><span class="text-fg-muted">:</span> <span class="text-fg-muted">&#123;</span>
    <span class="text-accent-cyan">css</span><span class="text-fg-muted">:</span> <span class="text-fg-muted">&#123;</span> <span class="text-accent-cyan">transformGroup</span><span class="text-fg-muted">:</span> <span class="text-accent-yellow">"css"</span> <span class="text-fg-muted">&#125;,</span>
    <span class="text-accent-cyan">ts</span><span class="text-fg-muted">:</span> <span class="text-fg-muted">&#123;</span> <span class="text-accent-cyan">transformGroup</span><span class="text-fg-muted">:</span> <span class="text-accent-yellow">"js"</span> <span class="text-fg-muted">&#125;</span>
  <span class="text-fg-muted">&#125;</span>
<span class="text-fg-muted">&#125;;</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- token reference table -->
  <section class="reveal bg-bg-secondary/50 px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="section-header">
        <h2 class="section-title">Token Reference</h2>
        <p class="section-desc">
          Complete mapping of every token with its CSS variable, Tailwind class,
          and theme values.
        </p>
      </div>
      <div class="border-border-default overflow-x-auto rounded-xl border">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-border-default bg-bg-tertiary border-b">
              <th class="text-fg-primary px-4 py-3 font-semibold">Token</th>
              <th class="text-fg-primary px-4 py-3 font-semibold"
                >CSS Variable</th
              >
              <th class="text-fg-primary px-4 py-3 font-semibold">Tailwind</th>
              <th class="text-fg-primary px-4 py-3 font-semibold">Dark Value</th
              >
              <th class="text-fg-primary px-4 py-3 font-semibold"
                >Light Value</th
              >
            </tr>
          </thead>
          <tbody>
            {
              tokenRef.map((t, i) => (
                <tr
                  class:list={[
                    "border-border-muted border-b",
                    i % 2 === 0 ? "bg-bg-primary" : "bg-bg-secondary/30",
                  ]}
                >
                  <td class="text-fg-primary px-4 py-2.5 font-mono text-xs">
                    {t.token}
                  </td>
                  <td class="text-accent-cyan px-4 py-2.5 font-mono text-xs">
                    {t.cssVar}
                  </td>
                  <td class="text-accent-pink px-4 py-2.5 font-mono text-xs">
                    {t.tailwind || "—"}
                  </td>
                  <td class="px-4 py-2.5 font-mono text-xs">
                    {t.dark.startsWith("#") ? (
                      <span class="inline-flex items-center gap-1.5">
                        <span
                          class="border-border-default inline-block h-3 w-3 rounded-sm border"
                          style={`background:${t.dark}`}
                        />
                        {t.dark}
                      </span>
                    ) : (
                      <span class="text-fg-muted">{t.dark}</span>
                    )}
                  </td>
                  <td class="px-4 py-2.5 font-mono text-xs">
                    {t.light.startsWith("#") ? (
                      <span class="inline-flex items-center gap-1.5">
                        <span
                          class="border-border-default inline-block h-3 w-3 rounded-sm border"
                          style={`background:${t.light}`}
                        />
                        {t.light}
                      </span>
                    ) : (
                      <span class="text-fg-muted">{t.light}</span>
                    )}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .theme-gradient {
    background: linear-gradient(
      135deg,
      var(--color-accent-purple),
      var(--color-accent-pink),
      var(--color-accent-cyan)
    );
    -webkit-background-clip: text;
